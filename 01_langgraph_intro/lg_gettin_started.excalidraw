    {
      "id": "98vROAPTcG9mMAjvkRzLb",
      "type": "text",
      "x": 254.73828125,
      "y": 226.58984375,
      "width": 1018.1793212890625,
      "height": 275,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
