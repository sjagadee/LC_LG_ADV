    {
      "id": "jWDVb30V_2W5a8i_pg48r",
      "type": "text",
      "x": 280,
      "y": 231,
      "width": 509.75958251953125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
